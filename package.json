{
  "name": "c0mpute-monorepo",
  "version": "0.2.18",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun run --filter=c0mpute dev",
    "dev:tui": "bun run --cwd apps/tui dev",
    "build": "bun run --cwd packages/shared build && bun run --filter=c0mpute build",
    "start": "bun run --filter=c0mpute start",
    "cargo:build": "cargo build --bins",
    "cargo:run": "cargo run --bin c0mpute --",
    "cargo:test": "cargo test --workspace",
    "newsletter": "bun bin/send-newsletter.ts",
    "migrate:cloud": "bun bin/migrate-to-cloud.ts",
    "export:cloud": "$HOME/.bun/bin/bun bin/export-from-cloud.ts"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.0"
  },
  "optionalDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0"
  },
  "dependencies": {
    "@sqlitecloud/drivers": "^1.0.880",
    "drizzle-orm": "^0.45.2",
    "postcss": "^8.5.15"
  }
}
